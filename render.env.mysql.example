# Render Web Service environment template (MySQL)
# Copy values into Render Dashboard -> Environment

NODE_ENV=production
PORT=10000
SESSION_SECRET=replace-with-long-random-secret
PUBLIC_APP_URL=https://your-app-name.onrender.com
# Set to false to create invites without sending email.
INVITE_EMAIL_ENABLED=true

DB_HOST=your-public-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=your-mysql-database
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECT_TIMEOUT_MS=10000

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app-name.onrender.com/api/auth/google/callback

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

JWT_SECRET=replace-with-long-random-secret
