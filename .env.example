# ============================================
# D-Box Environment Configuration
# ============================================

# Node Environment
NODE_ENV=development
PORT=5000

# ============================================
# AWS Configuration
# ============================================

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# AWS S3 Bucket
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_BUCKET_URL=https://your-bucket-name.s3.amazonaws.com

# AWS SES Configuration (Email Service)
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# Database Configuration
# ============================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=dbox

# MySQL (if using MySQL instead of PostgreSQL)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=dbox

# ============================================
# Session Configuration
# ============================================

# Session secret for signing session ID cookies
SESSION_SECRET=your_session_secret_key_change_this_in_production

# ============================================
# Authentication
# ============================================

# JWT Secret for token signing
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# ============================================
# Frontend Configuration
# ============================================

# Frontend URL for redirects and links
FRONTEND_URL=http://localhost:3000

# ============================================
# OTP Configuration
# ============================================

# Maximum OTP verification attempts
OTP_MAX_ATTEMPTS=5

# OTP resend cooldown in milliseconds (default: 30 seconds)
OTP_RESEND_COOLDOWN_MS=30000

# ============================================
# File Upload Configuration
# ============================================

# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=104857600

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# Google OAuth Configuration (Optional)
# ============================================

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ============================================
# Logging
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# Email Configuration (Deprecated - Using AWS SES)
# ============================================
# These variables are no longer used - AWS SES is used instead
# AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# Optional: Test Email Configuration
# ============================================

# Email for testing (used by GET /test-email)
TEST_EMAIL_TO=your_email@example.com
