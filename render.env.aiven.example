# Render env template for Aiven MySQL
# Copy these keys into Render -> Environment

NODE_ENV=production
PORT=10000
SESSION_SECRET=replace-with-long-random-secret
PUBLIC_APP_URL=https://d-box.onrender.com
# Set to false to create invites without sending email.
INVITE_EMAIL_ENABLED=true

DB_HOST=mysql-29ffcdc0-dbox.k.aivencloud.com
DB_PORT=15348
DB_USER=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=defaultdb
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CONNECT_TIMEOUT_MS=10000

# Prefer one of these CA options.
# Use DB_SSL_CA_BASE64 on Render if multiline paste is awkward.
DB_SSL_CA=
DB_SSL_CA_

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://d-box.onrender.com/api/auth/google/callback

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

JWT_SECRET=replace-with-long-random-jwt-secret
SESSION_SECRET=replace-with-long-random-session-secret

