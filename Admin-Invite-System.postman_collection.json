{
  "info": {
    "_postman_id": "admin-invite-system-collection",
    "name": "D-Box Admin Invite System",
    "description": "Complete API collection for Admin Invite System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Send Admin Invite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newmanager@example.com\",\n  \"role\": \"manager\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/send",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "send"]
        },
        "description": "Send admin invite to a new user. Requires admin role."
      },
      "response": []
    },
    {
      "name": "2. Validate Invite Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/validate/{{INVITE_TOKEN}}?email={{INVITE_EMAIL}}",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "validate", "{{INVITE_TOKEN}}"],
          "query": [
            {
              "key": "email",
              "value": "{{INVITE_EMAIL}}"
            }
          ]
        },
        "description": "Validate an invite token before acceptance"
      },
      "response": []
    },
    {
      "name": "3. Accept Invite & Create Account",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{INVITE_TOKEN}}\",\n  \"email\": \"{{INVITE_EMAIL}}\",\n  \"password\": \"SecurePassword123!\",\n  \"fullname\": \"John Manager\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/accept",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "accept"]
        },
        "description": "Accept invite and create new user account"
      },
      "response": []
    },
    {
      "name": "4. Get My Invites (All)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/my-invites?filter=all",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "my-invites"],
          "query": [
            {
              "key": "filter",
              "value": "all",
              "description": "all, pending, accepted, expired"
            }
          ]
        },
        "description": "Get all invites sent by current admin"
      },
      "response": []
    },
    {
      "name": "5. Get Pending Invites",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/my-invites?filter=pending",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "my-invites"],
          "query": [
            {
              "key": "filter",
              "value": "pending"
            }
          ]
        },
        "description": "Get pending invites (not yet accepted)"
      },
      "response": []
    },
    {
      "name": "6. Get Accepted Invites",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/my-invites?filter=accepted",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "my-invites"],
          "query": [
            {
              "key": "filter",
              "value": "accepted"
            }
          ]
        },
        "description": "Get accepted invites"
      },
      "response": []
    },
    {
      "name": "7. Filter Invites by Role",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/my-invites?filter=all&role=manager",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "my-invites"],
          "query": [
            {
              "key": "filter",
              "value": "all"
            },
            {
              "key": "role",
              "value": "manager",
              "description": "admin, manager, employee"
            }
          ]
        },
        "description": "Filter invites by specific role"
      },
      "response": []
    },
    {
      "name": "8. Get Invite Statistics",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/stats",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "stats"]
        },
        "description": "Get invite statistics and analytics"
      },
      "response": []
    },
    {
      "name": "9. Resend Invite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/resend/{{INVITE_ID}}",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "resend", "{{INVITE_ID}}"]
        },
        "description": "Resend invite email with new token"
      },
      "response": []
    },
    {
      "name": "10. Revoke Invite",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "connect.sid={{SESSION_ID}}"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/admin/invite/{{INVITE_ID}}",
          "host": ["{{BASE_URL}}"],
          "path": ["admin", "invite", "{{INVITE_ID}}"]
        },
        "description": "Revoke an unused invite"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "SESSION_ID",
      "value": "your_session_id_here",
      "type": "string"
    },
    {
      "key": "INVITE_TOKEN",
      "value": "token_from_send_invite_response",
      "type": "string"
    },
    {
      "key": "INVITE_EMAIL",
      "value": "user@example.com",
      "type": "string"
    },
    {
      "key": "INVITE_ID",
      "value": "1",
      "type": "string"
    }
  ]
}
